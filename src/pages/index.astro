---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import MainContent from '../components/MainContent.astro';

const personStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Fransisco Wiles',
  url: 'https://fransiscowiles.com/',
  image: 'https://fransiscowiles.com/article-images/suit-picture.jpg',
  jobTitle: 'Director of Paid Media',
  worksFor: {
    '@type': 'Organization',
    name: 'Webris',
    url: 'https://webris.org/',
  },
  sameAs: ['https://www.linkedin.com/in/fransisco-wiles/'],
};
---

<Layout
  title="Fransisco Wiles Marketing - Legal Marketing Expert"
  description="I help law firms and legal agencies run successful ad campaigns. Get higher quality leads, sign more cases, and take your firm to new heights."
  structuredData={personStructuredData}
>
  <Hero />
  <MainContent />
</Layout>
