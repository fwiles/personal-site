---
import Layout from "../layouts/Layout.astro";
---

<Layout
    title="Schedule a FREE Strategy Session | Fransisco Wiles"
    description="Book your free strategy session with Fransisco Wiles. Choose a time on the calendar to talk about your goals."
>
    <section class="schedule">
        <div class="container">
            <h1>Schedule a FREE Strategy Session</h1>
            <!-- iClosed inline widget begin -->
            <div
                class="iclosed-widget"
                data-url="https://app.iclosed.io/e/fwiles/free-strategy-call"
                title="FREE Strategy Call"
                style="width: 100%; height: 620px"
            >
            </div>
            <script
                type="text/javascript"
                src="https://app.iclosed.io/assets/widget.js"
                async></script>
            <!-- iClosed inline widget end -->
        </div>
    </section>
</Layout>

<style>
    .schedule {
        padding: var(--space-12) 0 var(--space-16);
        text-align: center;
    }

    .schedule :global(.container) {
        max-width: calc(var(--content-max-width) + 125px);
    }

    .schedule h1 {
        margin-bottom: var(--space-2);
    }

    @media (max-width: 768px) {
        .schedule h1 {
            margin-bottom: var(--space-8);
        }
    }
</style>
